{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./lib",
    "forceConsistentCasingInFileNames": true,
    "sourceMap": true,
    "strict": true,
    "module": "commonjs",
    "target": "ES6",
    "jsx": "react",
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "lib": ["ESNext", "DOM"],
    "esModuleInterop": true,
    "types": ["node"]
  },
  "include": ["src"],
  "references": [{"path": "./tsconfig.node.json"}]
}
